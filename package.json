{
  "name": "v4_1-itarang",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "next": "next dev",
    "worker": "tsx src/lib/queue/callWorker.ts",
    "dev:with-worker": "concurrently \"next dev\" \"npm run worker\"",
    "dev:no-turbo": "next dev --no-turbo",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:update-passwords": "node scripts/update-passwords.js",
    "db:seed-test": "tsx scripts/seed-test-data.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test --grep=\\[smoke\\]",
    "test:e2e:live": "playwright test --project=chromium-live",
    "test:e2e:manual": "playwright test --project=chromium-manual",
    "test:e2e:eval": "cross-env EXCEL_REPORT=1 playwright test",
    "test:e2e:prod-eval": "cross-env HEADED=1 E2E_ALLOW_PROD=1 E2E_BASE_URL=https://crm.itarang.com EXCEL_REPORT=1 playwright test --project=chromium-prod --workers=1",
    "test:e2e:prod-eval:mutations": "cross-env HEADED=1 E2E_ALLOW_PROD=1 E2E_PROD_MUTATIONS=1 E2E_BASE_URL=https://crm.itarang.com EXCEL_REPORT=1 playwright test --project=chromium-prod --workers=1",
    "test:e2e:prod-eval:headless": "cross-env E2E_ALLOW_PROD=1 E2E_BASE_URL=https://crm.itarang.com EXCEL_REPORT=1 playwright test --project=chromium-prod --workers=1"
  },
